# Public (embedded App Bridge). Must match SHOPIFY_API_KEY / Partner "Client ID".
NEXT_PUBLIC_SHOPIFY_API_KEY=

# Server-only Partner credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Comma-separated Admin API scopes (example)
SCOPES=read_products,write_products

# Full app URL with scheme, no trailing slash (use HTTPS in dev via tunnel, e.g. ngrok).
# Must match the origin in shopify.application_url (see shopify.app.toml); embedded path is /shopify/app.
SHOPIFY_APP_URL=https://your-host.example.com

# Shopify CLI (`shopify app dev`) also injects SHOPIFY_API_KEY, SHOPIFY_API_SECRET, SCOPES, HOST — optional to duplicate in .env.local.

# Set to "false" only for non-embedded apps (OAuth session cookie behavior differs).
# SHOPIFY_EMBEDDED=true
